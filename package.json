{
  "name": "mia-tui",
  "version": "1.0.0",
  "description": "",
  "bin": "dist/bundle.js",
  "main": "dist/bundle.js",
  "type": "module",
  "scripts": {
    "build": "esbuild index.mjs --bundle --platform=node --outfile=dist/bundle.js --external:neo-blessed --external:blessed --external:term.js --external:pty.js --external:blessed/lib/colors",
    "package": "pkg . --targets node18-linux-x64 --output xmail-linux",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "pkg": {
    "assets": [
      "node_modules/@pm2/blessed/**/*"
    ],
    "scripts": [
      "node_modules/@pm2/blessed/lib/widgets/*.js"
    ],
    "options": [
      "--no-bytecode"
    ]
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@pm2/blessed": "^0.1.81",
    "chalk": "^4.1.2",
    "execa": "^5.1.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2"
  }
}
